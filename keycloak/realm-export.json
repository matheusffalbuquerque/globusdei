{
  "realm": "globusdei",
  "enabled": true,
  "displayName": "Globus Dei",
  "registrationAllowed": true,
  "registrationEmailAsUsername": true,
  "verifyEmail": false,
  "loginWithEmailAllowed": true,
  "roles": {
    "realm": [
      {
        "name": "colaborador",
        "description": "Usuario interno que presta recursos e suporte"
      },
      {
        "name": "agente",
        "description": "Missionario, aluno ou proponente das iniciativas"
      },
      {
        "name": "administrador",
        "description": "Acesso total ao painel"
      }
    ]
  },
  "clients": [
    {
      "clientId": "globusdei-web",
      "name": "Globusdei Web Platform",
      "enabled": true,
      "publicClient": false,
      "secret": "mock-secret-for-dev",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": [
        "http://localhost:3000/*",
        "http://localhost:3001/*"
      ],
      "webOrigins": [
        "http://localhost:3000",
        "http://localhost:3001",
        "+"
      ],
      "protocol": "openid-connect",
      "fullScopeAllowed": true
    }
  ]
}
