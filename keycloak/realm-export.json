{
  "realm": "globusdei",
  "enabled": true,
  "displayName": "Globus Dei",
  "registrationAllowed": true,
  "registrationEmailAsUsername": true,
  "verifyEmail": false,
  "loginWithEmailAllowed": true,
  "roles": {
    "realm": [
      {
        "name": "colaborador",
        "description": "Usuario interno que presta recursos e suporte"
      },
      {
        "name": "agente",
        "description": "Missionario, aluno ou proponente das iniciativas"
      },
      {
        "name": "administrador",
        "description": "Acesso total ao painel"
      }
    ]
  },
  "clients": [
    {
      "clientId": "globusdei-web",
      "name": "Globusdei Web Platform",
      "enabled": true,
      "publicClient": false,
      "secret": "mock-secret-for-dev",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": [
        "http://localhost:3000/*",
        "http://localhost:3001/*"
      ],
      "webOrigins": [
        "http://localhost:3000",
        "http://localhost:3001",
        "+"
      ],
      "protocol": "openid-connect",
      "fullScopeAllowed": true,
      "defaultClientScopes": [
        "web-origins",
        "acr",
        "profile",
        "roles",
        "email"
      ],
      "optionalClientScopes": [
        "address",
        "phone",
        "offline_access",
        "microprofile-jwt"
      ]
    }
  ],
  "identityProviders": [
    {
      "alias": "google",
      "displayName": "Google",
      "providerId": "google",
      "enabled": true,
      "trustEmail": true,
      "storeToken": false,
      "addReadTokenRoleOnCreate": false,
      "authenticateByDefault": false,
      "linkOnly": false,
      "firstBrokerLoginFlowAlias": "first broker login",
      "config": {
        "clientId": "${env.KC_GOOGLE_CLIENT_ID}",
        "clientSecret": "${env.KC_GOOGLE_CLIENT_SECRET}",
        "defaultScope": "openid email profile",
        "syncMode": "IMPORT",
        "useJwksUrl": "true",
        "hostedDomain": "",
        "userIp": "false",
        "offlineAccess": "false"
      }
    }
  ],
  "identityProviderMappers": [
    {
      "name": "google-email-mapper",
      "identityProviderAlias": "google",
      "identityProviderMapper": "oidc-user-attribute-idp-mapper",
      "config": {
        "syncMode": "INHERIT",
        "user.attribute": "email",
        "claim": "email"
      }
    },
    {
      "name": "google-given-name-mapper",
      "identityProviderAlias": "google",
      "identityProviderMapper": "oidc-user-attribute-idp-mapper",
      "config": {
        "syncMode": "INHERIT",
        "user.attribute": "firstName",
        "claim": "given_name"
      }
    },
    {
      "name": "google-family-name-mapper",
      "identityProviderAlias": "google",
      "identityProviderMapper": "oidc-user-attribute-idp-mapper",
      "config": {
        "syncMode": "INHERIT",
        "user.attribute": "lastName",
        "claim": "family_name"
      }
    },
    {
      "name": "google-picture-mapper",
      "identityProviderAlias": "google",
      "identityProviderMapper": "oidc-user-attribute-idp-mapper",
      "config": {
        "syncMode": "INHERIT",
        "user.attribute": "picture",
        "claim": "picture"
      }
    }
  ]
}
