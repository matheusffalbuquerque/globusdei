# ─────────────────────────────────────────────────────────────────────────────
# Globus Dei — Variáveis de Ambiente
# Copie este arquivo para .env e preencha com os valores reais de produção
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=globusdei
POSTGRES_PASSWORD=TROQUE_POR_SENHA_FORTE
POSTGRES_DB=globusdei_db

# URL de conexão usada pelo Prisma nos serviços NestJS
# Em produção aponta para o container interno: postgres:5432
DATABASE_URL=postgresql://globusdei:TROQUE_POR_SENHA_FORTE@postgres:5432/globusdei_db?schema=app

# ── MongoDB ────────────────────────────────────────────────────────────────────
MONGO_USER=root
MONGO_PASSWORD=TROQUE_POR_SENHA_FORTE

# URL de conexão usada por data-service e report-service
MONGODB_URI=mongodb://root:TROQUE_POR_SENHA_FORTE@mongodb:27017/globusdei?authSource=admin

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=TROQUE_POR_SENHA_FORTE
REDIS_URL=redis://:TROQUE_POR_SENHA_FORTE@redis:6379

# ── RabbitMQ ───────────────────────────────────────────────────────────────────
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=TROQUE_POR_SENHA_FORTE
RABBITMQ_URL=amqp://guest:TROQUE_POR_SENHA_FORTE@rabbitmq:5672

# ── Keycloak (Admin Bootstrap) ─────────────────────────────────────────────────
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=TROQUE_POR_SENHA_FORTE

# Hostname externo do Keycloak (sem protocolo)
# Ex.: auth.seudominio.com  ou  localhost  (para local)
KEYCLOAK_HOSTNAME=localhost

# ── Keycloak (Configuração Google IdP) ────────────────────────────────────────
GOOGLE_CLIENT_ID=seu-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=TROQUE_PELO_SECRET_DO_GOOGLE

# ── Keycloak (Usado pelos serviços backend) ────────────────────────────────────
KEYCLOAK_REALM=globusdei
KEYCLOAK_CLIENT_ID=globusdei-app

# URL base do Keycloak acessível pelos containers internos
KEYCLOAK_URL=http://keycloak:8080

# Issuer e JWKS usados para validação de JWT nos serviços NestJS
KEYCLOAK_ISSUER=http://keycloak:8080/realms/globusdei
KEYCLOAK_JWKS_URI=http://keycloak:8080/realms/globusdei/protocol/openid-connect/certs

# ── Keycloak (Usado pelo web-platform / NextAuth) ──────────────────────────────
KEYCLOAK_CLIENT_SECRET=TROQUE_PELO_SECRET_DO_CLIENT_KEYCLOAK
KEYCLOAK_ADMIN_CLIENT_ID=admin-cli
KEYCLOAK_ADMIN_USERNAME=admin
# KEYCLOAK_ADMIN_PASSWORD já definido acima

# ── NextAuth ───────────────────────────────────────────────────────────────────
# URL pública da aplicação web (sem barra final)
NEXTAUTH_URL=https://seudominio.com

# Segredo aleatório de 32+ bytes — gere com: openssl rand -base64 32
NEXTAUTH_SECRET=TROQUE_POR_STRING_ALEATORIA_LONGA

# ── Segurança dos serviços ─────────────────────────────────────────────────────
# Chave AES-256 de 32 bytes usada pelo finance-service para criptografia
# Gere com: openssl rand -hex 16  (32 chars hex = 16 bytes)  ou  openssl rand -base64 24
ENCRYPTION_KEY=TROQUE_POR_CHAVE_DE_32_BYTES

# Token compartilhado para comunicação interna entre serviços
# Gere com: openssl rand -hex 32
INTERNAL_SERVICE_TOKEN=TROQUE_POR_TOKEN_INTERNO_SEGURO

# ── CORS ───────────────────────────────────────────────────────────────────────
# Lista de origens permitidas nos serviços backend (separadas por vírgula se múltiplas)
CORS_ORIGINS=https://seudominio.com

# ── URLs públicas dos serviços (NEXT_PUBLIC_ são expostas ao browser) ──────────
# Em produção com reverse proxy (nginx/traefik), aponte para o domínio externo
# Em Docker interno, use os nomes dos containers
NEXT_PUBLIC_MAIN_SERVICE_URL=https://seudominio.com/api/main
NEXT_PUBLIC_FINANCE_SERVICE_URL=https://seudominio.com/api/finance
NEXT_PUBLIC_NOTIFICATION_SERVICE_URL=https://seudominio.com/api/notification

# URL interna do serviço de notificações usada por rotas server-side
NOTIFICATION_SERVICE_URL=http://notification-service:3004/api

# ── E-mail / SMTP ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=comunica@globusdei.org
SMTP_PASS=TROQUE_PELA_SENHA_OU_APP_PASSWORD
MAIL_FROM_NAME=Globus Dei
MAIL_FROM_ADDRESS=comunica@globusdei.org
