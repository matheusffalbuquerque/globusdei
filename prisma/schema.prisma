// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Onboarding Phase Enum for tracking User Admission
enum AgentStatus {
  ENTERED             // Just registered, preparing application
  SUBMITTED           // Questionnaire completed, pending analysis
  SCHEDULED           // Inteview scheduled with google meet link
  FEEDBACK_PROVIDED   // Interview finished, evaluation emitted
  APPROVED            // Fully integrated into the ecosystem
  REJECTED            // Application denied
}

/// Agent model representing a user acting as a missionary, student, or professional seeking support.
/// Strictly implementing the Agent interface requirements from the shared domain models.
model Agent {
  id              String   @id @default(uuid())
  name            String
  email           String   @unique
  /// The specific role vocation context of this agent
  vocationType    String
  /// Comprehensive background detailing needs and history
  description     String   @db.Text
  isActive        Boolean  @default(true)
  
  /// Identifiers or relations to the Empreendimento initiatives the agent belongs to.
  empreendimentos EmpreendimentoAgent[]

  /// ONBOARDING STATE MACHINE
  status          AgentStatus @default(ENTERED)
  
  /// Contains the Google Meet link or external URL once status is SCHEDULED
  interviewLink   String?
  interviewDate   DateTime?
  /// UUID of the Collaborator handling the evaluation
  interviewerId   String?
  /// Missiological Feedback provided after the interview
  feedback        String?     @db.Text
  
  /// Form Answers array submitted by the agent
  answers         Answer[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

/// Empreendimento model representing an initiative, project, or organization.
model Empreendimento {
  id              String   @id @default(uuid())
  name            String
  /// Core mission statement and initiative objectives
  description     String   @db.Text
  establishedDate DateTime
  
  /// The specific agents formally connected to this initiative.
  agents          EmpreendimentoAgent[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

/// Join table for the many-to-many relationship bridging Agents and Empreendimentos.
model EmpreendimentoAgent {
  agentId           String
  empreendimentoId  String
  
  agent             Agent          @relation(fields: [agentId], references: [id], onDelete: Cascade)
  empreendimento    Empreendimento @relation(fields: [empreendimentoId], references: [id], onDelete: Cascade)

  @@id([agentId, empreendimentoId])
}

/// Event model representing online or physical sessions organized by Globus Dei.
/// Required by business specs to cluster online/offline events over the operational year.
model Event {
  id              String   @id @default(uuid())
  title           String
  description     String   @db.Text
  date            DateTime
  location        String?
  isOnline        Boolean  @default(false)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

/// AuditLog mapped strictly for LGPD constraints - tracking sensitive data access.
/// Records actions like: view sensitive missions data, elevation of privileges, or login faults.
model AuditLog {
  id              String   @id @default(uuid())
  /// The Keycloak Identity UUID or System Service who performed the action
  actorId         String   
  /// Types: SECURITY, TECHNICAL, AUDIT
  actionType      String   
  /// Specific description (e.g., VIEW_SENSITIVE_DATA, INVESTMENT_APPROVAL)
  actionDetail    String   
  timestamp       DateTime @default(now())
  ipAddress       String?
}

/// Dynamic Onboarding Questions definable by Staff
model Question {
  id              String   @id @default(uuid())
  title           String
  /// If true, the agent must fulfill this to submit the onboarding application
  isRequired      Boolean  @default(true)
  
  answers         Answer[]
  
  createdAt       DateTime @default(now())
}

/// A specific Agent's answer to an Onboarding Question
model Answer {
  id              String   @id @default(uuid())
  agentId         String
  questionId      String
  
  text            String   @db.Text
  
  agent           Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  question        Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  
  createdAt       DateTime @default(now())

  @@unique([agentId, questionId])
}
